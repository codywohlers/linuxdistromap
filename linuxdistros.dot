digraph linuxdistros {
// Graphviz dot Map of Linux Distributions

// NOTE: Very unstable graph, re-ordering any nodes will dramatically change the whole diagram.

// 2026-May-05 code@codywohlers.ca - initial creation.


label=<<table border="0" cellborder="0" cellpadding="0" cellspacing="0">
<tr><td colspan="2"><font point-size="36">Some Popular, Common, and Important Linux Distributions 2026</font></td></tr>
<tr><td colspan="2">The categories are common uses, but for the most part any distro is capable of being anything.  Logos are copyright and/or trademarks of their holders.  Made with Graphviz.</td></tr>
<tr><td align="right">2026-Mar-05 &nbsp;</td>
<td align="left" href="https://github.com/codywohlers/linuxdistromap" tooltip="https://github.com/codywohlers/linuxdistromap"><font color="blue">github.com/codywohlers/linuxdistromap</font></td>
</tr></table>>

labelloc=t
labeljust=c


// Dark Mode (experimental)
//bgcolor=black
//color=white
//fontcolor=white
//fontcolor=green
//edge [color=green] //constraint=false]


// Layout

rankdir=LR
ranksep=4

//ranksep=3

//layout=neato
//scale=3

//splines=polyline


fontname="Liberation Sans"
node [shape=box style=filled fillcolor=white fontname="Liberation Sans" color=white]
edge [color="#505050"]

